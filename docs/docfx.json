{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "../src",
          "files": ["**/*.csproj"],
          "exclude": ["OsuNet.Tests/*.csproj"]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "**/images/**",
          "logo/**.svg",
          "logo/**.png",
          "favicon.png"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "OsuNet",
      "_appTitle": "OsuNet Documentation",
      "_enableSearch": true,
      "_appLogoPath": "/logo/Logo.svg",
      "_appFaviconPath": "favicon.png"
    }
  }
}